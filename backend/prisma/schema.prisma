generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnchorTargetKind {
  EVM
  SOLANA
}

enum AnchorDispatchStatus {
  PENDING
  CLAIMED
  SUBMITTED
  CONFIRMED
  FAILED_RETRYABLE
  FAILED_FINAL
}

enum AssemblyState {
  DRAFT
  SEALED
  IN_SERVICE
  OPENED
  MISMATCHED
  RETIRED
}

enum ComponentState {
  REGISTERED
  INSTALLED
  REMOVED
  RETIRED
}

enum InspectionResult {
  MATCH
  MISMATCH
  INCOMPLETE
}

enum RepairerTier {
  OEM_MANUFACTURING
  OEM_REPAIRER
  APPROVED_REPAIRER
  TIER_2_CERTIFIED
  OUTSIDE_NETWORK
  OWNER_SELF_FIT
}

enum NetworkFitmentStatus {
  INSIDE_OEM_NETWORK
  INSIDE_APPROVED_NETWORK
  CERTIFIED_LOWER_TIER
  OUTSIDE_NETWORK
  EVIDENCE_MISSING
}

enum AuthenticationSubjectType {
  COMPONENT
  VEHICLE_ASSEMBLY
  FITMENT_EVENT
  REPAIR_EVENT
  INSPECTION_ITEM
}

enum WarrantyImpact {
  NONE
  REVIEW_REQUIRED
  WARRANTY_RISK
  EXCLUDED_FROM_COVERAGE
  UNKNOWN
}

enum RepairEventStatus {
  OPEN
  AWAITING_AUTHENTICATION
  COMPLETED
  WARRANTY_REVIEW
  CANCELLED
}

enum RepairEventItemAction {
  BOOK_OFF
  BOOK_ON
  VERIFY_PRESENT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum CampaignSeverity {
  SERVICE_ACTION
  SAFETY_RECALL
  CRITICAL_SAFETY
  SOFTWARE_RECALL
}

enum CampaignExposureStatus {
  TARGETED
  REPAIR_BOOKED
  CLEARED
  UNKNOWN
}

model Component {
  componentUid         String                     @id
  serial               String                     @unique
  partNumber           String
  manufacturer         String?
  description          String?
  state                ComponentState             @default(REGISTERED)
  createdAt            DateTime                   @default(now())
  memberships          AssemblyMembership[]
  inspectionItems      InspectionItem[]
  authenticationEvents AuthenticationEvent[]
  repairItems          RepairEventItem[]          @relation("RepairItemComponent")
  replacementItems     RepairEventItem[]          @relation("RepairItemReplacementFor")
  campaignExposures    AssemblyCampaignExposure[]

  @@index([partNumber])
  @@index([manufacturer])
}

model Assembly {
  assemblyUid          String                     @id
  assetType            String
  label                String
  status               AssemblyState              @default(DRAFT)
  currentCustodianId   String?
  currentLocationId    String?
  externalReference    String?                    @unique
  datamatrixPayload    String?                    @unique
  createdAt            DateTime                   @default(now())
  memberships          AssemblyMembership[]
  snapshots            AssemblySnapshot[]
  inspections          Inspection[]
  repairEvents         RepairEvent[]
  campaignExposures    AssemblyCampaignExposure[]
  authenticationEvents AuthenticationEvent[]

  @@index([assetType])
  @@index([label])
}

model AssemblyMembership {
  id                   String                     @id @default(uuid())
  assemblyUid          String
  componentUid         String
  positionLabel        String?
  addedAt              DateTime                   @default(now())
  removedAt            DateTime?
  expectedRole         String?
  assembly             Assembly                   @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: Cascade)
  component            Component                  @relation(fields: [componentUid], references: [componentUid], onDelete: Cascade)
  authenticationEvents AuthenticationEvent[]
  repairEventItems     RepairEventItem[]
  campaignExposures    AssemblyCampaignExposure[]

  @@unique([assemblyUid, componentUid])
  @@index([assemblyUid, removedAt])
  @@index([componentUid])
}

model Repairer {
  id                   String                @id @default(uuid())
  name                 String
  tier                 RepairerTier
  networkStatus        NetworkFitmentStatus
  approvedByOem        Boolean               @default(false)
  oemReference         String?
  createdAt            DateTime              @default(now())
  users                PlatformUser[]
  repairEvents         RepairEvent[]
  authenticationEvents AuthenticationEvent[]

  @@index([tier])
  @@index([networkStatus])
  @@index([approvedByOem])
}

model PlatformUser {
  id                   String                @id @default(uuid())
  displayName          String
  email                String?               @unique
  role                 String
  organisationName     String?
  repairerId           String?
  createdAt            DateTime              @default(now())
  repairer             Repairer?             @relation(fields: [repairerId], references: [id], onDelete: SetNull)
  openedRepairEvents   RepairEvent[]         @relation("RepairEventOpenedBy")
  repairItemAuths      RepairEventItem[]     @relation("RepairItemAuthenticatedBy")
  authenticationEvents AuthenticationEvent[]

  @@index([repairerId])
  @@index([role])
}

model AuthenticationEvent {
  id                    String                    @id @default(uuid())
  subjectType           AuthenticationSubjectType
  assemblyUid           String?
  componentUid          String?
  membershipId          String?
  authenticatedByUserId String
  repairerId            String?
  networkStatus         NetworkFitmentStatus
  warrantyImpact        WarrantyImpact            @default(UNKNOWN)
  evidenceHash          String?
  notes                 String?
  authenticatedAt       DateTime                  @default(now())
  assembly              Assembly?                 @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: SetNull)
  component             Component?                @relation(fields: [componentUid], references: [componentUid], onDelete: SetNull)
  membership            AssemblyMembership?       @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  authenticatedBy       PlatformUser              @relation(fields: [authenticatedByUserId], references: [id], onDelete: Restrict)
  repairer              Repairer?                 @relation(fields: [repairerId], references: [id], onDelete: SetNull)

  @@index([subjectType])
  @@index([assemblyUid])
  @@index([componentUid])
  @@index([membershipId])
  @@index([authenticatedByUserId])
  @@index([repairerId])
  @@index([networkStatus, warrantyImpact])
  @@index([authenticatedAt])
}

model RepairEvent {
  id               String            @id @default(uuid())
  assemblyUid      String
  repairerId       String?
  openedByUserId   String?
  status           RepairEventStatus @default(OPEN)
  reason           String
  warrantyClaimRef String?
  serviceOrderRef  String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  notes            String?
  assembly         Assembly          @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: Cascade)
  repairer         Repairer?         @relation(fields: [repairerId], references: [id], onDelete: SetNull)
  openedBy         PlatformUser?     @relation("RepairEventOpenedBy", fields: [openedByUserId], references: [id], onDelete: SetNull)
  items            RepairEventItem[]

  @@index([assemblyUid, openedAt])
  @@index([repairerId])
  @@index([openedByUserId])
  @@index([status])
  @@index([warrantyClaimRef])
  @@index([serviceOrderRef])
}

model RepairEventItem {
  id                    String                @id @default(uuid())
  repairEventId         String
  action                RepairEventItemAction
  componentUid          String?
  replacementForUid     String?
  membershipId          String?
  positionLabel         String?
  expectedSerial        String?
  observedSerial        String?
  networkStatus         NetworkFitmentStatus
  warrantyImpact        WarrantyImpact        @default(UNKNOWN)
  authenticatedByUserId String?
  authenticatedAt       DateTime?
  notes                 String?
  createdAt             DateTime              @default(now())
  repairEvent           RepairEvent           @relation(fields: [repairEventId], references: [id], onDelete: Cascade)
  component             Component?            @relation("RepairItemComponent", fields: [componentUid], references: [componentUid], onDelete: SetNull)
  replacementFor        Component?            @relation("RepairItemReplacementFor", fields: [replacementForUid], references: [componentUid], onDelete: SetNull)
  membership            AssemblyMembership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  authenticatedBy       PlatformUser?         @relation("RepairItemAuthenticatedBy", fields: [authenticatedByUserId], references: [id], onDelete: SetNull)

  @@index([repairEventId])
  @@index([action])
  @@index([componentUid])
  @@index([replacementForUid])
  @@index([membershipId])
  @@index([networkStatus, warrantyImpact])
  @@index([authenticatedByUserId])
}

model SafetyCampaign {
  id           String                     @id @default(uuid())
  campaignCode String                     @unique
  title        String
  severity     CampaignSeverity
  status       CampaignStatus             @default(DRAFT)
  launchedAt   DateTime?
  closedAt     DateTime?
  notes        String?
  createdAt    DateTime                   @default(now())
  targets      CampaignComponentTarget[]
  exposures    AssemblyCampaignExposure[]

  @@index([status, severity])
  @@index([launchedAt])
}

model CampaignComponentTarget {
  id           String         @id @default(uuid())
  campaignId   String
  partNumber   String
  serialPrefix String?
  description  String?
  campaign     SafetyCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([partNumber])
  @@index([serialPrefix])
}

model AssemblyCampaignExposure {
  id             String                 @id @default(uuid())
  campaignId     String
  assemblyUid    String
  componentUid   String?
  membershipId   String?
  exposureStatus CampaignExposureStatus @default(TARGETED)
  detectedAt     DateTime               @default(now())
  clearedAt      DateTime?
  notes          String?
  campaign       SafetyCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assembly       Assembly               @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: Cascade)
  component      Component?             @relation(fields: [componentUid], references: [componentUid], onDelete: SetNull)
  membership     AssemblyMembership?    @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([assemblyUid])
  @@index([componentUid])
  @@index([membershipId])
  @@index([exposureStatus])
  @@index([detectedAt])
}

model AssemblySnapshot {
  snapshotRef     String           @id @default(cuid())
  assemblyUid     String
  snapshotType    String           @default("EXPECTED_CONFIGURATION")
  contentHash     String           @unique
  componentCount  Int
  createdAt       DateTime         @default(now())
  createdByUserId String?
  createdByOrgId  String?
  assembly        Assembly         @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: Cascade)
  dispatches      AnchorDispatch[]

  @@index([assemblyUid, createdAt])
}

model Inspection {
  id              String           @id @default(uuid())
  assemblyUid     String
  result          InspectionResult @default(INCOMPLETE)
  inspectorUserId String?
  inspectorOrgId  String?
  notes           String?
  observedHash    String?
  inspectedAt     DateTime         @default(now())
  assembly        Assembly         @relation(fields: [assemblyUid], references: [assemblyUid], onDelete: Cascade)
  items           InspectionItem[]

  @@index([assemblyUid, inspectedAt])
}

model InspectionItem {
  id             String     @id @default(uuid())
  inspectionId   String
  componentUid   String?
  observedSerial String
  positionLabel  String?
  matched        Boolean    @default(false)
  varianceReason String?
  inspection     Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  component      Component? @relation(fields: [componentUid], references: [componentUid], onDelete: SetNull)

  @@index([inspectionId])
  @@index([observedSerial])
}

model AnchorTarget {
  targetKey       String           @id
  label           String
  targetKind      AnchorTargetKind
  networkName     String?
  chainId         Int?
  contractAddress String?
  programId       String?
  explorerBaseUrl String?
  enabled         Boolean          @default(true)
  isPrimary       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  dispatches      AnchorDispatch[]
  receipts        AnchorReceipt[]

  @@index([enabled])
  @@index([targetKind])
}

model AnchorDispatch {
  id            String               @id @default(uuid())
  snapshotRef   String
  targetKey     String
  status        AnchorDispatchStatus @default(PENDING)
  attempts      Int                  @default(0)
  nextAttemptAt DateTime?
  queuedAt      DateTime             @default(now())
  claimedAt     DateTime?
  completedAt   DateTime?
  lastError     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  snapshot      AssemblySnapshot     @relation(fields: [snapshotRef], references: [snapshotRef], onDelete: Cascade)
  target        AnchorTarget         @relation(fields: [targetKey], references: [targetKey], onDelete: Cascade)
  receipt       AnchorReceipt?

  @@unique([snapshotRef, targetKey])
  @@index([targetKey, status, nextAttemptAt, queuedAt])
}

model AnchorReceipt {
  id               String         @id @default(uuid())
  dispatchId       String         @unique
  targetKey        String
  submissionRef    String?        @unique
  transactionRef   String?        @unique
  blockHeight      Int?
  slot             Int?
  anchoredAt       DateTime?
  submitLatencyMs  Int?
  confirmLatencyMs Int?
  createdAt        DateTime       @default(now())
  dispatch         AnchorDispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  target           AnchorTarget   @relation(fields: [targetKey], references: [targetKey], onDelete: Cascade)

  @@index([targetKey, anchoredAt])
}
